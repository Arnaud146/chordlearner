# Supabase client-side (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Supabase server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OCR providers (server-only, optional)
OCR_SPACE_API_KEY=your-ocr-space-api-key
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key
# Google Vision async PDF (server-only, optional)
# Choose one credential source:
GOOGLE_CLOUD_VISION_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# or:
GOOGLE_CLOUD_VISION_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json
GOOGLE_CLOUD_VISION_PDF_BUCKET=your-gcs-bucket-for-vision
# Optional tuning:
GOOGLE_CLOUD_VISION_PDF_TIMEOUT_MS=90000
GOOGLE_CLOUD_VISION_PDF_POLL_INTERVAL_MS=1500

# Web extraction (server-only, optional)
WEB_EXTRACTION_TIMEOUT_MS=12000

# Distributed rate limiting (server-only, optional but recommended in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Product quotas per authenticated user (server-only, optional overrides)
QUOTA_OCR_UPLOAD_DAY=40
QUOTA_OCR_UPLOAD_MONTH=600
QUOTA_OCR_DETECT_DAY=80
QUOTA_OCR_DETECT_MONTH=1200
QUOTA_CHORD_EXTRACTION_DAY=100
QUOTA_CHORD_EXTRACTION_MONTH=2000

# Emergency security switch (server-only)
OCR_KILL_SWITCH=false

# Optional alert destination (Slack/Discord/custom webhook)
SECURITY_ALERT_WEBHOOK_URL=

# Optional CSRF allowlist for cross-origin trusted frontends (comma-separated)
# Example: ALLOWED_ORIGINS=https://your-domain.vercel.app,https://www.your-domain.com
ALLOWED_ORIGINS=
